<?xml version="1.0" encoding="utf-8"?>
<!--
  cally only talks to user-configured OpenAI-compatible STT endpoints, and
  only when transcription is opted in. We require HTTPS for every request:
  the bearer token (user's API key) MUST NOT travel over plaintext, even if
  a typo / redirect downgrades the scheme.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
