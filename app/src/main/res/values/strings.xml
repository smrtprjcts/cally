    <!-- Accessibility — required for reliable background FG service start -->
    <string name="accessibility_service_summary">Дозволяє автоматичний запис дзвінків</string>
    <string name="accessibility_service_description">cally використовує службу спеціальних можливостей для надійного автоматичного старту запису, коли надходить дзвінок. Жодних подій не зчитуємо — служба потрібна лише для дозволу запускати запис у фоні.</string>

    <!-- Onboarding step 5 (overlay permission for FGS-from-background) -->
    <string name="onboarding_step_overlay">Поверх інших додатків</string>
    <string name="onboarding_step_overlay_desc">Дозвіл малювати поверх — потрібен для автозапису з фону. Ми додаємо невидимий 1×1 px шар на ~3 секунди, щоб Android дозволив стартувати запис під час дзвінка.</string>
    <string name="onboarding_step_overlay_action">Дозволити</string>

    <!-- Onboarding step 6 (battery exemption) -->
    <string name="onboarding_step_battery">Без сну</string>
    <string name="onboarding_step_battery_desc">Samsung та Pixel заморожують додатки, коли вони не на екрані. Без цього дозволу cally не зможе ввімкнутися сама, щоб записати дзвінок.</string>
    <string name="onboarding_step_battery_action">Дозволити</string>

