    <!-- Legal -->
    <string name="legal_title">Before you record</string>
    <string name="legal_intro">Jurisdictions fall into three tiers. Find yours — and act accordingly. This is not legal advice.</string>

    <string name="legal_tier1_title">1. No notification (one-party consent)</string>
    <string name="legal_tier1_summary">Ukraine, UK, federal USA + ~38 states, Canada, Australia, Poland.</string>
    <string name="legal_tier1_body">A participant of a conversation may record without notifying the other party. Your own consent = sufficient consent. Basis: federal Wiretap Act 18 U.S.C. § 2511 in the USA, RIPA 2000 in the UK, Criminal Code § 184(2)(a) in Canada.</string>

    <string name="legal_tier2_title">2. Notification required (all-party + implied consent)</string>
    <string name="legal_tier2_summary">~11 US states: California, Illinois, Florida, Maryland, etc.</string>
    <string name="legal_tier2_body">Full list: CA (Penal Code § 632), FL, IL, MD, MA, MT, NV, NH, PA, WA, CT. Notify the caller at the start — if they hear it and continue, that is implied consent, recording is legal. This doctrine is established by decades of case law. Same mechanism as EU hotline disclaimers.</string>

    <string name="legal_tier3_title">3. Forbidden even with notification (explicit consent)</string>
    <string name="legal_tier3_summary">Germany, Austria, Belgium. Explicit consent required — notification is not enough.</string>
    <string name="legal_tier3_body">Germany — § 201 StGB, up to 3 years for recording “non-public speech” without explicit permission. Implied consent is not recognized in private conversations. Austria — § 120 StGB. Belgium — criminal law + electronic communications, often requiring written consent. Do not use cally in these jurisdictions without explicit “yes, I agree”.</string>

    <string name="legal_tech_title">cally and beep to the caller</string>
    <string name="legal_tech_body">Technically we cannot play a beep or announcement into the caller’s ear — this is a Pixel Phone system privilege, unavailable to third‑party apps. Verbal notice at the start works in tier 2 (implied consent). In tier 3 it is insufficient — explicit consent is required.</string>

    <string name="legal_share">Recording ≠ distribution. Publishing without consent is the user’s responsibility — even in one‑party jurisdictions.</string>
    <string name="legal_footer">Details and sources — in the project README.</string>
    <string name="legal_action_accept">Understood, continue</string>
    <string name="legal_action_close">Close</string>
