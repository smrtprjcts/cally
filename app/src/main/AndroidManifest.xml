<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      INTERNET is required for cloud transcription only — audio is sent to a
      user-configured OpenAI-compatible endpoint (default: OpenRouter with
      Gemini Flash). Transcription is OPT-IN: it runs only when the user
      taps "Розпізнати мову" on a record AND has entered an API key in
      Settings. Recording itself never touches the network. The endpoint URL
      is fully user-configurable so privacy-conscious users can point at a
      self-hosted LM Studio / Ollama server.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Telephony state for auto-detect of OFFHOOK/IDLE transitions. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Persistent recording notification + heads-up. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      FGS type=specialUse: the actual microphone access happens in the
      Shizuku UserService (UID shell), not in our process, so we don't need
      type=microphone. specialUse is not subject to the Android 14+
      "FGS-from-background" restriction. RECORD_AUDIO is still required
      because the Builder requires it on the calling-context attribution.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!--
      Android 14+ (target SDK 34+) blocks foreground services of type
      microphone when started from BroadcastReceiver / Doze background.
      SYSTEM_ALERT_WINDOW is the canonical exemption — apps that can draw
      overlays are allowed to start FG services from background. Without
      this, CallStateReceiver → startForegroundService(microphone) crashes
      with SecurityException.
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
      Battery optimization exemption — without this, our foreground service
      gets paused/killed during long calls when the device enters Doze.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--
      Shizuku Manager grants this on first request; nothing else uses it.
      Without it the bindUserService call fails with SecurityException.
    -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <queries>
        <package android:name="moe.shizuku.privileged.api" />
    </queries>

    <application
        android:name=".App"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:enableOnBackInvokedCallback="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.Callrec.Splash"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:localeConfig="@xml/locale_config"
        tools:targetApi="33">

        <!-- Required by Shizuku UserService binding from API V23. -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!-- Share recordings via Intent.ACTION_SEND with content:// URIs. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Callrec.Splash"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|density|navigation|locale|fontScale|fontWeightAdjustment"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          FGS type is `specialUse`, not `microphone`: the actual AudioRecord
          lives in the Shizuku UserService process (shell UID, separate
          process) — not in this FGS. Claiming `microphone` here would be
          architecturally wrong and would invoke Android's mic-attribution
          enforcement against a process that never opens a mic.

          The subtype string is the disclosure shown in Play's runtime
          metadata. Pair it with a Data-Safety section explaining cloud STT
          is opt-in and disabled by default.
        -->
        <service
            android:name=".telephony.CallMonitorService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Call recording. Audio is captured in a separate Shizuku UserService process (UID 2000); this FGS only coordinates lifecycle, notification, and storage. Recordings stay on-device unless the user enables cloud transcription." />
        </service>

        <!--
          Transparent zero-UI activity used by CallMonitorService.onTaskRemoved
          to keep the process foreground when the user swipes the app from
          Recents — keeps FGS from being reaped.
        -->
        <activity
            android:name=".ui.DummyActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:launchMode="singleInstance"
            android:finishOnTaskLaunch="true" />

        <!--
          Auto-detect: fires on every telephony state change, even when the
          app process is dead. PHONE_STATE is gated by READ_PHONE_STATE which
          we already request at runtime.
        -->
        <receiver
            android:name=".telephony.CallStateReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!--
          MediaButtonReceiver is required by androidx.media for the
          MediaStyle notification's transport buttons + Bluetooth-headset
          media keys to actually reach our MediaSession. Without it,
          tapping play/pause in the notification or on a wired/wireless
          remote is a silent no-op.
        -->
        <receiver
            android:name="androidx.media.session.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

        <!--
          Empty AccessibilityService. Declared so user can enable us in
          Settings → Accessibility, which unlocks the platform's exemption
          to start FG services with type=microphone from background
          (BroadcastReceiver, Doze, etc). BIND_ACCESSIBILITY_SERVICE
          permission is signature-only, but the service itself is empty
          and observes nothing.
        -->
        <service
            android:name=".accessibility.CallrecAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>
</manifest>
